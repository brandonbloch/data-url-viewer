{
  "name": "data-url-viewer",
  "description": "Decode and display various data URL types",
  "version": "0.1.0",
  "type": "module",
  "author": {
    "name": "Brandon Bloch",
    "url": "https://bloch.ca",
    "email": "brandon@bloch.ca"
  },
  "homepage": "https://bloch.ca/data-url-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonbloch/data-url-viewer.git"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.59.3"
  }
}
